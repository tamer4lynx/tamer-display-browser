{
  "name": "@tamer4lynx/tamer-display-browser",
  "version": "0.0.4",
  "publishConfig": {
    "access": "public",
    "tag": "prerelease"
  },
  "type": "module",
  "description": "Open URLs in system browser for Lynx.",
  "main": "dist/index.js",
